# AccuKnox xBOM Scan — example pipeline.
#
# Define ACCUKNOX_ENDPOINT, ACCUKNOX_TOKEN and ACCUKNOX_LABEL as *secret*
# pipeline variables (Pipelines -> Library, or the pipeline's Variables tab).
#
# Runs on Linux, macOS and Windows agents; the matching CLI build is
# downloaded automatically.

trigger:
  branches:
    include:
      - main
      - master

pool:
  vmImage: ubuntu-latest

steps:
- checkout: self

# --- SBOM from the source tree -----------------------------------------------
- task: AccuKnox-xBOM@2
  displayName: AccuKnox SBOM Scan
  inputs:
    bomType: sbom
    scanPath: '.'
    accuknoxEndpoint: $(ACCUKNOX_ENDPOINT)
    accuknoxToken: $(ACCUKNOX_TOKEN)
    accuknoxLabel: $(ACCUKNOX_LABEL)
    projectName: my-project
    projectClassifier: application

